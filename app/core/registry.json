{
  "providers": {
    "anthropic": {
      "name": "Claude Pro",
      "icon": "🟠",
      "api_key_label": "API Token (api)",
      "api_key_help": "Official OAuth access token for Claude (sk-ant-...). Found in ~/.config/claude/oauth_creds.json",
      "session_cookie_label": "Web Session (web)",
      "session_cookie_help": "Manual browser session bundle (sessionKey). Use this if OAuth is unavailable.",
      "rules": [
        {
          "type": "env",
          "variable": "CLAUDE_CODE_OAUTH_TOKEN",
          "mapping": { "value": "oauth_token" }
        },
        {
          "type": "file",
          "paths": [
            "~/.claude/.credentials.json",
            "{{CONFIG_DIR:claude}}/.credentials.json"
          ],
          "format": "json",
          "mapping": {
            "claudeAiOauth.accessToken": "oauth_token",
            "claudeAiOauth.refreshToken": "refresh_token",
            "claudeAiOauth.clientId": "client_id",
            "oauthAccount.emailAddress|oauthAccount.email": "account_id",
            "oauthAccount.email|oauthAccount.emailAddress": "account_label"
          }
        },
        {
          "type": "keychain",
          "service": "Claude Code-credentials",
          "format": "json",
          "mapping": {
            "claudeAiOauth.accessToken": "oauth_token",
            "claudeAiOauth.refreshToken": "refresh_token",
            "claudeAiOauth.clientId": "client_id",
            "oauthAccount.emailAddress|oauthAccount.email": "account_id",
            "oauthAccount.email|oauthAccount.emailAddress": "account_label"
          }
        },
        {
          "type": "cookie",
          "domains": ["anthropic.com", ".anthropic.com", "claude.ai", ".claude.ai"],
          "name": "sessionKey",
          "mapping": { "value": "cookie_sessionKey" }
        },
        {
          "type": "file_json_statusline",
          "paths": [
            "~/.claude/statusline.json",
            "{{CONFIG_DIR:claude}}/statusline.json"
          ]
        },
        {
          "type": "env",
          "variable": "CLAUDE_SESSION_TOKEN",
          "mapping": { "value": "session_cookie" }
        }
      ]
    },
    "openrouter": {
      "name": "OpenRouter",
      "icon": "🚀",
      "api_key_label": "API Key (api)",
      "api_key_help": "Your OpenRouter API key (sk-or-...)",
      "rules": [
        {
          "type": "env",
          "variable": "OPENROUTER_API_KEY",
          "mapping": { "value": "api_key" }
        }
      ]
    },
    "minimax": {
      "name": "MiniMax",
      "icon": "🤖",
      "api_key_label": "API Key (api)",
      "api_key_help": "MiniMax official API key",
      "session_cookie_label": "Web Session (web)",
      "session_cookie_help": "Manual browser cookie for HTML scraping/web fallback",
      "rules": [
        {
          "type": "env",
          "variable": "MINIMAX_API_KEY",
          "mapping": { "value": "api_key" }
        },
        {
          "type": "env",
          "variable": "MINIMAX_COOKIE",
          "mapping": { "value": "session_cookie" }
        }
      ]
    },
    "github": {
      "name": "GitHub API",
      "icon": "🐙",
      "api_key_label": "Personal Access Token (api)",
      "api_key_help": "A GitHub PAT with 'read:user' or Copilot permissions",
      "rules": [
        {
          "type": "env",
          "variable": "GITHUB_TOKEN",
          "mapping": { "value": "api_key" }
        },
        {
          "type": "file",
          "paths": [
            "{{CONFIG_DIR:runway}}/github_oauth.json"
          ],
          "format": "json",
          "mapping": { "access_token": "api_key" }
        },
        {
          "type": "file",
          "paths": [
            "~/.config/gh/hosts.yml",
            "{{CONFIG_DIR:gh}}/hosts.yml"
          ],
          "format": "yaml",
          "mapping": {
            "github.com.oauth_token": "api_key",
            "github.com.user": "account_id"
          }
        },
        {
          "type": "windows_credential",
          "target": "github.com",
          "mapping": { "value": "api_key" }
        }
      ]
    },
    "gemini": {
      "name": "Gemini API",
      "icon": "🔵",
      "api_key_label": "OAuth Token (api)",
      "api_key_help": "The access_token string from ~/.gemini/oauth_creds.json",
      "rules": [
        {
          "type": "file",
          "paths": [
            "~/.gemini/oauth_creds.json",
            "{{CONFIG_DIR:gemini}}/oauth_creds.json"
          ],
          "format": "json",
          "mapping": {
            "access_token": "oauth_token",
            "refresh_token": "refresh_token",
            "id_token": "id_token",
            "expiry_date": "expiry_date",
            "client_id": "client_id",
            "clientId": "client_id",
            "account_label": "account_label"
          }
        }
      ]
    },
    "chatgpt": {
      "name": "ChatGPT Codex",
      "icon": "💬",
      "api_key_label": "Bearer Token (api)",
      "api_key_help": "The Bearer eyJ... string from ChatGPT DevTools Network tab",
      "session_cookie_label": "Web Session (web)",
      "session_cookie_help": "Paste your full cookie string from DevTools → Application → Cookies → chatgpt.com. Include __Secure-next-auth.session-token.0, .1, and oai-sc if present (modern browsers split the session token into chunks).",
      "rules": [
        {
          "type": "env",
          "variable": "CHATGPT_OAUTH_TOKEN",
          "mapping": { "value": "oauth_token" }
        },
        {
          "type": "file",
          "paths": [
            "~/.codex/auth.json",
            "{{CONFIG_DIR:codex}}/auth.json"
          ],
          "format": "json",
          "mapping": {
            "tokens.access_token": "oauth_token",
            "tokens.refresh_token": "refresh_token",
            "tokens.id_token": "id_token",
            "tokens.account_id": "account_id"
          }
        },
        {
          "type": "cookie",
          "domains": ["chatgpt.com"],
          "name": "__Secure-next-auth.session-token",
          "mapping": { "value": "cookie___Secure-next-auth.session-token" }
        },
        {
          "type": "cookie",
          "domains": ["chatgpt.com"],
          "name": "__Secure-next-auth.session-token.0",
          "mapping": { "value": "cookie___Secure-next-auth.session-token.0" }
        },
        {
          "type": "cookie",
          "domains": ["chatgpt.com"],
          "name": "__Secure-next-auth.session-token.1",
          "mapping": { "value": "cookie___Secure-next-auth.session-token.1" }
        },
        {
          "type": "cookie",
          "domains": ["chatgpt.com"],
          "name": "oai-sc",
          "mapping": { "value": "cookie_oai-sc" }
        },
        {
          "type": "env",
          "variable": "CHATGPT_SESSION_TOKEN",
          "mapping": { "value": "session_cookie" }
        }
      ]
    },
    "kimi_coding": {
      "name": "Kimi Coding",
      "icon": "🌙",
      "session_cookie_label": "Auth Token (web)",
      "session_cookie_help": "Bearer token or session cookie for Kimi Coding web dashboard",
      "rules": [
        {
          "type": "env",
          "variable": "KIMI_AUTH_TOKEN",
          "mapping": { "value": "session_cookie" }
        }
      ]
    },
    "kimi": {
      "name": "Kimi API",
      "icon": "🌙",
      "api_key_label": "API Key (api)",
      "api_key_help": "Moonshot official API key (sk-...)",
      "rules": [
        {
          "type": "env",
          "variable": "KIMI_AUTH_TOKEN",
          "mapping": { "value": "cookie_kimi-auth" }
        },
        {
          "type": "env",
          "variable": "KIMI_API_KEY",
          "mapping": { "value": "api_key" }
        },
        {
          "type": "cookie",
          "domains": ["kimi.moonshot.cn", "kimi.com"],
          "name": "kimi-auth",
          "mapping": { "value": "cookie_kimi-auth" }
        }
      ]
    },
    "zai": {
      "name": "zAI API",
      "icon": "🌐",
      "api_key_label": "API Key (api)",
      "api_key_help": "zAI official API key",
      "rules": [
        {
          "type": "env",
          "variable": "ZAI_API_KEY",
          "mapping": { "value": "api_key" }
        }
      ]
    },
    "kimi_api": {
      "name": "Kimi API",
      "icon": "🌙",
      "api_key_label": "API Key (api)",
      "api_key_help": "Moonshot API key (sk-...)",
      "rules": [
        {
          "type": "env",
          "variable": "KIMI_API_KEY",
          "mapping": { "value": "api_key" }
        }
      ]
    },
    "kimi_k2": {
      "name": "Kimi K2",
      "icon": "🌙",
      "api_key_label": "API Key (api)",
      "api_key_help": "Kimi K2 official API key",
      "rules": [
        {
          "type": "env",
          "variable": "KIMI_K2_API_KEY",
          "mapping": { "value": "api_key" }
        }
      ]
    },
    "opencode": {
      "name": "OpenCode",
      "icon": "⚡",
      "session_cookie_label": "Auth Cookie (web)",
      "session_cookie_help": "Paste the 'auth' cookie value from opencode.ai",
      "rules": [
        {
          "type": "cookie",
          "domains": ["opencode.ai", ".opencode.ai"],
          "name": "auth",
          "mapping": { "value": "cookie_session" }
        },
        {
          "type": "sqlite",
          "paths": [
            "~/.local/share/opencode/opencode.db",
            "{{DATA_DIR:opencode}}/opencode.db"
          ],
          "queries": [
            {
              "name": "Usage (5h/7d/30d)",
              "query": "SELECT SUM(json_extract(data, '$.cost')), COUNT(*) FROM message WHERE time_created > ? AND json_valid(data) AND json_extract(data, '$.role') = 'assistant'",
              "windows": {
                "5h": 18000,
                "week": 604800,
                "month": 2592000
              },
              "limits": {
                "5h": 12.0,
                "week": 30.0,
                "month": 60.0
              }
            }
          ]
        }
      ]
    },
    "antigravity": {
      "name": "Antigravity",
      "icon": "🛸",
      "rules": [
        {
          "type": "file_json_data",
          "paths": [
            "~/.antigravity/state/quota.json",
            "{{DATA_DIR:antigravity}}/state/quota.json"
          ]
        }
      ]
    },
    "ollama": {
      "name": "Ollama Cloud",
      "icon": "🦙",
      "description": "Monitor your Ollama Cloud usage. REQUIRES a session cookie (ollama_session) from ollama.com, not an API key.",
      "session_cookie_label": "Web Session (web)",
      "session_cookie_help": "Paste the 'session' or 'ollama_session' cookie value from ollama.com",
      "rules": [
        {
          "type": "env",
          "variable": "OLLAMA_SESSION_TOKEN",
          "mapping": { "value": "session_cookie" }
        },
        {
          "type": "cookie",
          "domains": ["ollama.com", ".ollama.com"],
          "name": "session",
          "mapping": { "value": "session_cookie" }
        },
        {
          "type": "cookie",
          "domains": ["ollama.com", ".ollama.com"],
          "name": "ollama_session",
          "mapping": { "value": "session_cookie" }
        },
        {
          "type": "cookie",
          "domains": ["ollama.com", ".ollama.com"],
          "name": "__Host-ollama_session",
          "mapping": { "value": "session_cookie" }
        },
        {
          "type": "cookie",
          "domains": ["ollama.com", ".ollama.com"],
          "name": "__Secure-next-auth.session-token",
          "mapping": { "value": "session_cookie" }
        },
        {
          "type": "cookie",
          "domains": ["ollama.com", ".ollama.com"],
          "name": "__Secure-session",
          "mapping": { "value": "session_cookie" }
        },
        {
          "type": "cookie",
          "domains": ["ollama.com", ".ollama.com", "signin.ollama.com"],
          "name": "access-token",
          "mapping": { "value": "session_cookie" }
        }
      ]
    }
  }
}
