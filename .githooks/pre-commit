#!/usr/bin/env bash
# Pre-commit hook: run ruff check + format on staged Python files.
# Auto-applies ruff format fixes and re-stages them so the commit is clean.
set -euo pipefail

VENV=".venv"

if [ ! -d "$VENV" ]; then
    echo "pre-commit: .venv not found — run 'make install' first" >&2
    exit 1
fi

# Collect staged .py files (excluding deleted ones)
STAGED=$(git diff --cached --name-only --diff-filter=d | grep '\.py$' || true)

if [ -z "$STAGED" ]; then
    exit 0
fi

echo "pre-commit: ruff check..."
"$VENV/bin/ruff" check $STAGED

echo "pre-commit: ruff format..."
"$VENV/bin/ruff" format $STAGED
# Re-stage any files ruff format changed
git add $STAGED

echo "pre-commit: pytest (unit tests)..."
"$VENV/bin/pytest" tests/unit/ --ignore=tests/unit/test_browser_cookies.py -q

echo "pre-commit: done."
