#  ╔─────────────────────────────────────────────────────────────────────────────╗
#  ║  🏃 Runway — AI Usage Tracker                                               ║
#  ║  🔐 Environment for docker-compose.traefik.yml (public HTTPS via Traefik)   ║
#  ╚─────────────────────────────────────────────────────────────────────────────╝
#
#  Setup:
#    1. cp .env.traefik.example .env
#    2. Fill in the values below (everything between < > is a placeholder).
#    3. docker compose -f docker-compose.traefik.yml up -d
#
#  This file covers the deployment/security flags that the Traefik topology
#  REQUIRES. For provider credentials (GITHUB_TOKEN, ZAI_API_KEY, cookies, …)
#  copy the relevant lines from .env.example — they apply unchanged.
#
#  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── Reverse proxy (read by docker compose) ───────────────────────────────────
# Public DNS name routed to Runway. Must have an A record pointing at this host.
RUNWAY_HOST=runway.example.com
# Let's Encrypt contact address (cert expiry notices).
ACME_EMAIL=you@example.com

# ─── Multi-host security gate (REQUIRED — server fails fast without these) ─────
# Behind a proxy APP_HOST != 127.0.0.1, which trips the startup gate. All four
# below become mandatory. See docs/SECURITY.md.
APP_HOST=0.0.0.0
# Traefik terminates TLS, so assert it here.
TLS_TERMINATED=true
# Comma-separated origin allow-list. Use your public https:// origin.
CORS_ORIGINS=https://runway.example.com
# 32-byte URL-safe base64 key for sensitive metadata at rest. Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DB_ENCRYPTION_KEY=

# ─── Sidecar ingestion ────────────────────────────────────────────────────────
# Shared HMAC secret between the server and every sidecar. Sidecars point at the
# PUBLIC URL (https://${RUNWAY_HOST}) — ingest rides through Traefik on :443, not
# a host port. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_API_KEY=

# ─── Admin & proxy trust (recommended for a public deployment) ────────────────
# Protects admin/config endpoints from non-localhost callers. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=
# Traefik's container IP on the `proxy` network. Without this, the per-source-IP
# ingest rate limiter sees only Traefik's IP and collapses every sidecar into a
# single 600/min bucket; setting it makes Runway honor X-Forwarded-For (which
# Traefik sets) and bucket per real client. Also gates X-Forwarded-User admin
# auth. Find it with: docker inspect -f '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}' traefik
# (pin Traefik to a static IP if you rely on this — the match is exact, not CIDR).
# TRUSTED_PROXY_IPS=

# ─── Display ──────────────────────────────────────────────────────────────────
# TZ=Europe/Berlin
