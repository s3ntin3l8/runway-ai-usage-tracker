#  ╔─────────────────────────────────────────────────────────────────────────────╗
#  ║  🏃 Runway — AI Usage Tracker                                               ║
#  ║  ⚙️  Configuration                                                           ║
#  ╚─────────────────────────────────────────────────────────────────────────────╝
#
#  Setup Instructions:
#    1. Copy this file to .env: `cp .env.example .env`
#    2. Fill in the keys for the services you use.
#    3. Restart Runway to apply changes.
#
#  Everything is optional. A freshly copied .env boots on localhost with zero
#  edits — uncomment only what you need. Lines without a leading `#` carry the
#  app's own defaults; commented lines show the default/example for reference.
#
#  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── Network & Core ───────────────────────────────────────────────────────────
# APP_HOST: 127.0.0.1 = local only (secure, default) | 0.0.0.0 = all interfaces.
# Binding to anything other than localhost trips the multi-host security gate
# below (CORS_ORIGINS + TLS_TERMINATED + DB_ENCRYPTION_KEY become mandatory).
APP_HOST=127.0.0.1
APP_PORT=8765

# ─── Multi-host / reverse proxy ───────────────────────────────────────────────
# These three are REQUIRED (server refuses to start) when APP_HOST != 127.0.0.1.
# Localhost binds ignore them. See docs/SECURITY.md.
#
# Public HTTPS behind Traefik? Use .env.traefik.example instead — it ships the
# full flag set for that topology. See docs/deployment.md → "Docker behind Traefik".

# CORS_ORIGINS: Comma-separated allow-list of browser origins. The legacy `["*"]`
# fallback is rejected by browsers for credentialed requests, so an explicit
# value is required off-localhost.
# Example: CORS_ORIGINS=http://my-server:8765,http://192.168.1.100:8765
# CORS_ORIGINS=

# TLS_TERMINATED: Assert that something in front of Runway (nginx, caddy,
# cloudflare, kube ingress, Traefik) terminates TLS. Sidecar payloads carry
# OAuth tokens and cookies; HMAC protects integrity, not confidentiality.
# Set to true once TLS is actually in place.
TLS_TERMINATED=false

# TRUSTED_PROXY_IPS: Comma-separated reverse-proxy source IPs allowed to (a)
# assert admin identity via a forward-auth identity header (Authentik, Authelia,
# Cloudflare Access, oauth2-proxy) and (b) supply the real client IP via
# X-Forwarded-For for per-client rate limiting. Empty = proxy-header auth
# disabled — without an allow-list these headers are trivially forged.
# Example: TRUSTED_PROXY_IPS=10.0.0.5,10.0.0.6
# TRUSTED_PROXY_IPS=

# FORWARD_AUTH_*_HEADER: Header names the trusted proxy asserts identity in.
# Defaults match the oauth2-proxy/Authelia convention (X-Forwarded-User/-Email/
# -Groups); a CGI-style Remote-User is always accepted as a user-header fallback.
# For Authentik, point these at its outpost's native headers instead — no
# proxy-side header renaming needed:
# FORWARD_AUTH_USER_HEADER=X-authentik-username
# FORWARD_AUTH_EMAIL_HEADER=X-authentik-email
# FORWARD_AUTH_GROUPS_HEADER=X-authentik-groups

# FORWARD_AUTH_ALLOWED_GROUPS / FORWARD_AUTH_ALLOWED_USERS: Optional
# defense-in-depth allow-list on top of TRUSTED_PROXY_IPS. Comma-separated;
# empty (default) trusts any user the proxy asserts. When set, an asserted
# user matching neither list doesn't get proxy trust — falls through to the
# session cookie / ADMIN_API_KEY break-glass path instead of a hard failure.
# FORWARD_AUTH_ALLOWED_GROUPS=runway-admins
# FORWARD_AUTH_ALLOWED_USERS=

# ─── State & Storage ──────────────────────────────────────────────────────────
# RUNWAY_CONFIG_DIR: Override the default platform-specific configuration directory.
# Defaults to `~/.config/runway` on Linux, `~/Library/Application Support/runway`
# on macOS, and `%APPDATA%\runway` on Windows.
# RUNWAY_CONFIG_DIR=/path/to/custom/config

# DATABASE_PATH: Path to the SQLite database. Defaults to <config dir>/runway.db.
# DATABASE_PATH=./data/runway.db

# DB_ENCRYPTION_KEY: 32-byte URL-safe base64 key encrypting sensitive metadata
# (tokens, cookies, ingest keys) at rest. REQUIRED when APP_HOST != 127.0.0.1,
# and whenever ADMIN_API_KEY is set. Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DB_ENCRYPTION_KEY=

# ─── Ingestion & Admin ────────────────────────────────────────────────────────
# INGEST_API_KEY: HMAC-signing secret shared between the server and every
# sidecar. The ingest endpoint stays DISABLED until this is a non-empty,
# non-default value. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_API_KEY=

# ADMIN_API_KEY: Protects admin-only endpoints (provider config, webhooks, token
# refresh). If unset, those endpoints are open to anyone with network access.
# Requires DB_ENCRYPTION_KEY when set. Generate as above.
ADMIN_API_KEY=

# RUNWAY_API_URL: URL of the Runway server. Used by `make sidecar` to point the
# local sidecar at the right server. Defaults to http://localhost:8765.
RUNWAY_API_URL=http://localhost:8765

# ─── Behavior & Display ───────────────────────────────────────────────────────
# BROWSER_PREFERENCE: Order of browsers to search for cookies.
# Options: safari, chrome, chromium, edge, firefox.
BROWSER_PREFERENCE=safari,chrome,chromium,edge,firefox

# LOG_FORMAT: "plain" (default, human-readable) or "json" (structured logs).
# LOG_FORMAT=plain

# TZ: Optional IANA timezone for dashboard timestamps (heatmap, events, history,
# forecast). When unset, the dashboard auto-detects from the browser; a per-user
# Settings override takes precedence over this. Standard Linux/Docker env var.
# Examples: TZ=Europe/Berlin | TZ=America/New_York | TZ=Asia/Tokyo
# TZ=

# ─── Advanced Tuning (optional) ───────────────────────────────────────────────
# Sensible defaults ship in code — override only if you have a reason. Values
# shown are the defaults.
#
# Background OAuth auto-refresh: keeps JWT-bearing tokens fresh even when the
# poller is dormant.
# TOKEN_AUTO_REFRESH_ENABLED=true
# TOKEN_AUTO_REFRESH_INTERVAL_SECONDS=300    # how often the refresh loop runs
# TOKEN_AUTO_REFRESH_THRESHOLD_SECONDS=600   # refresh tokens expiring within this
#
# Claude fallback token ceilings — used only when a tier limit can't be derived
# from the provider response.
# CLAUDE_MAX_LIMIT=10000000
# CLAUDE_PRO_LIMIT=2000000
# CLAUDE_FREE_LIMIT=500000
#
# KEYCHAIN_PROMPT_MODE: macOS keychain prompt behavior. "always" (default).
# KEYCHAIN_PROMPT_MODE=always

# ─── Provider Credentials ──────────────────────────────────────────────────────
#
# Credentials marked [UI] can also be set or overridden in the Runway settings UI.
# Credentials marked [Auto] are auto-discovered from local files if the CLI is installed (no action needed).
# Credentials marked [sidecar] can be extracted and forwarded by the Runway sidecar (useful in Docker/multi-host mode).

# ── API Keys (generated on provider's web dashboard) [UI] ──────────────────────
# Note: inline comments after KEY= are passed literally by Docker Compose — put
# your value right after the = and leave no trailing text, or it becomes the value.
# github.com → Settings → Tokens (or 'gh auth login', or use Device Flow in Runway) [UI]
GITHUB_TOKEN=
# api.z.ai → Dashboard [UI]
ZAI_API_KEY=
# api.moonshot.cn → Dashboard [UI]
KIMI_API_KEY=
# platform.moonshot.cn → Dashboard [UI]
KIMI_K2_API_KEY=
# openrouter.ai/keys [UI]
OPENROUTER_API_KEY=
# api.minimaxi.com → Dashboard [UI]
MINIMAX_API_KEY=
# API key for OpenCode Go billing [UI]
OPENCODE_GO_API_KEY=

# ── Provider endpoint overrides (optional) ─────────────────────────────────────
# Point a provider at an alternate host/endpoint. Most users leave these unset.
# ZAI_API_HOST=open.bigmodel.cn          # zAI host override (e.g. China region)
# ZAI_QUOTA_URL=                         # full URL to the zAI quota endpoint
# MINIMAX_HOST=platform.minimaxi.com     # MiniMax host override (e.g. China region)
# OPENROUTER_HTTP_REFERER=               # sent as HTTP-Referer to OpenRouter (app attribution)
# OPENROUTER_X_TITLE=Runway              # sent as X-Title to OpenRouter (app attribution)

# ── Browser Cookies (auto-scraped from local browsers) ───────────────────────
# Automatically extracted from your browser when running on the host.
# Browser support: Safari (macOS), Firefox, Chrome (with caveats), Chromium, Edge.
# ⚠️ Chrome/Edge: macOS fails with v127+ (App-Bound Encryption), Windows uses DPAPI, Linux works.
#     Use Firefox or Safari if Chrome/Edge auto-scraping doesn't work.
# Copy from DevTools → Application → Cookies if auto-scraping fails. See: docs/troubleshooting.md
# ollama.com → cookie 'session' [Auto] [UI] [sidecar]
OLLAMA_SESSION_TOKEN=
# kimi.com/code → cookie 'kimi-auth' [Auto] [UI] [sidecar]
KIMI_AUTH_TOKEN=
# chatgpt.com → cookie [Auto] [sidecar]
CHATGPT_OAUTH_TOKEN=
# minimax.com → cookie (fallback) [Auto] [UI] [sidecar]
MINIMAX_COOKIE=
# claude.ai → cookie [Auto] [sidecar]
CLAUDE_CODE_OAUTH_TOKEN=

# ── Auto-Discovered Files (no action needed if the CLI is installed) [Auto] [sidecar] ───
# The app automatically reads credential files written by their respective CLIs.
# No .env config needed if the CLI is installed.
# For Docker deployments without host access, the sidecar script can extract these instead.
#
# Provider            CLI that writes the file              Discovered from
# ─────────────────── ──────────────────────────────────── ─────────────────────────────────
# Claude              Claude CLI / claude.ai                ~/.config/claude/oauth_creds.json        [Auto] [sidecar]
# Gemini              Gemini CLI / gemini.google.com        ~/.gemini/oauth_creds.json              [Auto] [sidecar]
# ChatGPT / Codex     Codex CLI                            ~/.codex/auth.json                      [Auto] [sidecar]
# Antigravity IDE     Antigravity CLI                      ~/.local/share/antigravity/state/quota.json [Auto] [sidecar]
# OpenCode            OpenCode CLI                         ~/.local/share/opencode/opencode.db     [Auto] [sidecar]
# GitHub              Runway OAuth (Device Flow)           ~/.config/runway/github_oauth.json      [Auto] [sidecar]
#
# ── Optional OAuth client overrides (only if running your own OAuth app) ──────
# Leave blank to use the bundled OAuth client IDs.
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=
# CLAUDE_OAUTH_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e
# GITHUB_CLIENT_ID=Iv1.b507a08c87ecfe98

# ─── Sidecar (remote agent) — optional ────────────────────────────────────────
# Read by scripts/sidecar.py. `make sidecar` sources this .env, so server and
# sidecar stay aligned on the same host. Remote sidecars set these on their own host.
# RUNWAY_API_KEY=                   # auth key for ingestion; falls back to INGEST_API_KEY
# SIDECAR_BOOTSTRAP_DAYS=90         # days of history to backfill on first collection
# CLAUDE_CONFIG_DIR=                # comma-separated extra Claude config dirs to scan for logs
# OPENCODE_ACCOUNT_LABEL=           # label/identity override for OpenCode accounts
# OPENCODE_WORKSPACE_ID=            # OpenCode workspace ID override (fallback if not in DB)
