#  ╔─────────────────────────────────────────────────────────────────────────────╗
#  ║  🏃 Runway — AI Usage Tracker                                               ║
#  ║  ⚙️  Configuration                                                           ║
#  ╚─────────────────────────────────────────────────────────────────────────────╝
#
#  Setup Instructions:
#    1. Copy this file to .env: `cp .env.example .env`
#    2. Fill in the keys for the services you use.
#    3. Restart Runway to apply changes.
#
#  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── Network & Core ───────────────────────────────────────────────────────────
# 127.0.0.1 = Local only (secure, default) | 0.0.0.0 = All interfaces
APP_HOST=127.0.0.1
APP_PORT=8765

# CORS_ORIGINS: Comma-separated list of allowed origins for cross-origin requests.
# Required when accessing Runway from a different host or IP address.
# Example (Docker / LAN access):
# CORS_ORIGINS=http://my-server:8765,http://192.168.1.100:8765
# CORS_ORIGINS=

# ─── State & Security ─────────────────────────────────────────────────────────
# RUNWAY_CONFIG_DIR: Override the default platform-specific configuration directory.
# Defaults to `~/.config/runway-tracker` on Linux, `~/Library/Application Support/runway-tracker` on macOS,
# and `%APPDATA%\runway-tracker` on Windows.
# RUNWAY_CONFIG_DIR=/path/to/custom/config

# DATABASE_PATH: Path to the SQLite database. Defaults to platform config dir.
# DATABASE_PATH=./data/runway.db

# DB_ENCRYPTION_KEY: Optional 32-byte URL-safe base64 key for encrypting
# sensitive metadata in the database.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DB_ENCRYPTION_KEY=

# INGEST_API_KEY: API key for sidecar ingestion (external metrics from other hosts).
# Generate a strong key with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Ingest is DISABLED until this is changed from the default.
INGEST_API_KEY=

# ADMIN_API_KEY: Protects the dashboard and admin API endpoints (config, webhooks, refresh).
# 1. Access from 127.0.0.1 (Localhost) remains automated and does not require this key.
# 2. Remote / Docker / Proxy access will prompt for this key via a Login Screen.
# 3. Once entered, the key is saved in your browser's localStorage for future sessions.
# 4. If using a Reverse Proxy with auth, Runway will trust X-Forwarded-User / Remote-User headers.
# Unset = No authentication (NOT recommended for remote access).
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# ─── Local Collection ─────────────────────────────────────────────────────────
# LOCAL_COLLECTOR_ENABLED: Scrape local log files from CLI tools (Antigravity, OpenCode, etc).
# Set to false if running in Docker without host access. The sidecar can handle this instead.
LOCAL_COLLECTOR_ENABLED=true

# LOCAL_CREDENTIAL_SCRAPING_ENABLED: Extract credentials from browser cookies, keychain, and local files.
# Set to false if running in Docker without host access. The sidecar can handle this instead.
LOCAL_CREDENTIAL_SCRAPING_ENABLED=true

# BROWSER_PREFERENCE: Order of browsers to search for cookies.
# Options: safari, chrome, chromium, edge, firefox.
BROWSER_PREFERENCE=safari,chrome,chromium,edge,firefox

# ─── Provider Credentials ──────────────────────────────────────────────────────
#
# Credentials marked [UI] can also be set or overridden in the Runway settings UI.
# Credentials marked [Auto] are auto-discovered from local files if the CLI is installed (no action needed).
# Credentials marked [sidecar] can be extracted and forwarded by the Runway sidecar (useful in Docker/multi-host mode).

# ── API Keys (generated on provider's web dashboard) [UI] ──────────────────────
# github.com → Settings → Tokens (or 'gh auth login') [UI]
GITHUB_TOKEN=
# api.z.ai → Dashboard [UI]
ZAI_API_KEY=
# api.moonshot.cn → Dashboard [UI]
KIMI_API_KEY=
# platform.moonshot.cn → Dashboard [UI]
KIMI_K2_API_KEY=
# openrouter.ai/keys [UI]
OPENROUTER_API_KEY=
# api.minimaxi.com → Dashboard [UI]
MINIMAX_API_KEY=
# API key for OpenCode Go billing [UI]
OPENCODE_GO_API_KEY=

# ── Browser Cookies (auto-scraped if LOCAL_CREDENTIAL_SCRAPING_ENABLED=true) ───
# Automatically extracted from your browser if the setting above is enabled.
# Browser support: Safari (macOS), Firefox, Chrome (with caveats), Chromium, Edge.
# ⚠️ Chrome/Edge: macOS fails with v127+ (App-Bound Encryption), Windows uses DPAPI, Linux works.
#     Use Firefox or Safari if Chrome/Edge auto-scraping doesn't work.
# Copy from DevTools → Application → Cookies if auto-scraping fails. See: docs/troubleshooting.md
OLLAMA_SESSION_TOKEN=           # ollama.com → cookie 'session' [Auto] [UI] [sidecar]
KIMI_AUTH_TOKEN=                # kimi.com/code → cookie 'kimi-auth' [Auto] [UI] [sidecar]
CHATGPT_OAUTH_TOKEN=            # chatgpt.com → cookie [Auto] [sidecar]
MINIMAX_COOKIE=                 # minimax.com → cookie (fallback) [Auto] [UI] [sidecar]
CLAUDE_CODE_OAUTH_TOKEN=        # claude.ai → cookie [Auto] [sidecar]

# ── Auto-Discovered Files (no action needed if the CLI is installed) [Auto] [sidecar] ───
# The app automatically reads credential files written by their respective CLIs if
# LOCAL_CREDENTIAL_SCRAPING_ENABLED=true. No .env config needed if the CLI is installed.
# For Docker deployments without host access, the sidecar script can extract these instead.
#
# Provider            CLI that writes the file              Discovered from
# ─────────────────── ──────────────────────────────────── ─────────────────────────────────
# Claude              Claude CLI / claude.ai                ~/.config/claude/oauth_creds.json        [Auto] [sidecar]
# Gemini              Gemini CLI / gemini.google.com        ~/.gemini/oauth_creds.json              [Auto] [sidecar]
# ChatGPT / Codex     Codex CLI                            ~/.codex/auth.json                      [Auto] [sidecar]
# Antigravity IDE     Antigravity CLI                      ~/.local/share/antigravity/state/quota.json [Auto] [sidecar]
# OpenCode            OpenCode CLI                         ~/.local/share/opencode/opencode.db     [Auto] [sidecar]
# GitHub              Runway OAuth (Device Flow)           ~/.config/runway-tracker/github_oauth.json [Auto] [sidecar]
#
# ── Optional OAuth client overrides (only if running your own OAuth app) ──────
#
# Gemini: Leave blank to use the bundled OAuth client ID
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=
