#  ╔─────────────────────────────────────────────────────────────────────────────╗
#  ║  🏃 Runway — AI Usage Tracker                                               ║
#  ║  ⚙️  Configuration                                                           ║
#  ╚─────────────────────────────────────────────────────────────────────────────╝
#
#  Setup Instructions:
#    1. Copy this file to .env: `cp .env.example .env`
#    2. Fill in the keys for the services you use.
#    3. Restart Runway to apply changes.
#
#  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── Network & Core ───────────────────────────────────────────────────────────
# 127.0.0.1 = Local only (secure, default) | 0.0.0.0 = All interfaces
APP_HOST=127.0.0.1
APP_PORT=8765

# CORS_ORIGINS: Comma-separated list of allowed origins for cross-origin requests.
# Required when accessing Runway from a different host or IP address.
# Example (Docker / LAN access):
# CORS_ORIGINS=http://my-server:8765,http://192.168.1.100:8765
# CORS_ORIGINS=

# ─── State & Security ─────────────────────────────────────────────────────────
# DATABASE_PATH: Path to the SQLite database. Defaults to platform config dir.
# DATABASE_PATH=./data/runway.db

# DB_ENCRYPTION_KEY: Optional 32-byte URL-safe base64 key for encrypting
# sensitive metadata in the database.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DB_ENCRYPTION_KEY=

# INGEST_API_KEY: API key for sidecar ingestion (external metrics from other hosts).
# Generate a strong key with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Ingest is DISABLED until this is changed from the default.
INGEST_API_KEY=

# ADMIN_API_KEY: Protects admin-only endpoints (provider config, webhooks, token refresh).
# If not set, these endpoints are open to anyone with network access.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# ─── Local Collection ─────────────────────────────────────────────────────────
# LOCAL_COLLECTOR_ENABLED: Set to false if running in Docker without host access.
LOCAL_COLLECTOR_ENABLED=true

# LOCAL_CREDENTIAL_SCRAPING_ENABLED: Attempt to find credentials in local files/keychain.
LOCAL_CREDENTIAL_SCRAPING_ENABLED=true

# BROWSER_PREFERENCE: Order of browsers to search for cookies.
# Options: safari, chrome, chromium, edge, firefox.
# Default: safari,chrome,chromium,edge,firefox
BROWSER_PREFERENCE=chrome,safari,firefox

# ─── Provider Credentials ──────────────────────────────────────────────────────
#
# Credentials marked [UI] can also be set or overridden in the Runway settings UI.
# Credentials marked [Auto] are auto-discovered from local files if the CLI is
# installed (no action needed).

# ── API Keys (generated on provider's web dashboard) [UI] ──────────────────────

# GitHub Copilot: github.com → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=

# ZAI: api.z.ai → Dashboard
ZAI_API_KEY=

# Kimi API: api.moonshot.cn → Dashboard
KIMI_API_KEY=

# Kimi K2 API: platform.moonshot.cn → Dashboard
KIMI_K2_API_KEY=

# OpenRouter: openrouter.ai/keys
OPENROUTER_API_KEY=

# MiniMax IDE: api.minimaxi.com → Dashboard
MINIMAX_API_KEY=

# OpenCode Go: API key for OpenCode Go billing
OPENCODE_GO_API_KEY=

# ── Browser Cookies (copy from DevTools → Application → Cookies) [UI] ───────

# Ollama Cloud: ollama.com → DevTools → cookie named 'session'
OLLAMA_SESSION_TOKEN=

# Kimi Coding (IDE quota): kimi.com/code → DevTools → cookie named 'kimi-auth'
KIMI_AUTH_TOKEN=

# ChatGPT / Codex (manual override — auto-discovered if Codex CLI is installed)
CHATGPT_OAUTH_TOKEN=

# MiniMax (cookie fallback if API key is insufficient)
MINIMAX_COOKIE=

# Claude.ai (manual override — auto-discovered if Claude CLI is installed)
CLAUDE_CODE_OAUTH_TOKEN=

# ── Auto-Discovered Files (no action needed if the CLI is installed) [Auto] ───
# The app automatically reads credential files written by their respective CLIs.
# No configuration needed if you have the CLI installed and authenticated.
#
# Provider            CLI that writes the file              Discovered from
# ─────────────────── ──────────────────────────────────── ────────────────────
# Claude              Claude CLI / claude.ai                ~/.claude/oauth_creds.json
# Gemini              Gemini CLI / gemini.google.com        ~/.gemini/oauth_creds.json
# ChatGPT / Codex     Codex CLI                            ~/.codex/auth.json
# Antigravity IDE     Antigravity CLI                      ~/.antigravity/state/quota.json
# OpenCode            OpenCode CLI                         ~/.local/share/opencode/opencode.db
#
# ── Optional OAuth client overrides (only if running your own OAuth app) ──────
#
# Gemini: Leave blank to use the bundled OAuth client ID
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=
