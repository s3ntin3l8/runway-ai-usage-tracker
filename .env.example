#  ╔─────────────────────────────────────────────────────────────────────────────╗
#  ║  🏃 Runway — AI Usage Tracker                                               ║
#  ║  ⚙️  Configuration                                                           ║
#  ╚─────────────────────────────────────────────────────────────────────────────╝
#
#  Setup Instructions:
#    1. Copy this file to .env: `cp .env.example .env`
#    2. Fill in the keys for the services you use.
#    3. Restart Runway to apply changes.
#
#  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── Network & Core ───────────────────────────────────────────────────────────
# 127.0.0.1 = Local only (secure, default) | 0.0.0.0 = All interfaces
APP_HOST=127.0.0.1
APP_PORT=8765

# CORS_ORIGINS: Comma-separated list of allowed origins. 
# Defaults to http://localhost:8765 if not set.
# CORS_ORIGINS=http://localhost:8765,http://127.0.0.1:8765

# ─── State & Persistence (Phase 1) ────────────────────────────────────────────
# DATABASE_PATH: Path to the SQLite database. Defaults to platform config dir.
# DATABASE_PATH=./data/runway.db

# DB_ENCRYPTION_KEY: Optional 32-byte URL-safe base64 key for encrypting
# sensitive metadata in the database.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DB_ENCRYPTION_KEY=

# INGEST_API_KEY: API key for external metrics (sidecar scripts on other hosts).
# Generate a strong key with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Ingest is DISABLED until this is changed from the default.
INGEST_API_KEY=

# ─── Browser & Local Collection (Phase 2) ─────────────────────────────────────
# LOCAL_COLLECTOR_ENABLED: Set to false if running in Docker without host access.
LOCAL_COLLECTOR_ENABLED=true

# LOCAL_CREDENTIAL_SCRAPING_ENABLED: Attempt to find credentials in local files/keychain.
LOCAL_CREDENTIAL_SCRAPING_ENABLED=true

# BROWSER_PREFERENCE: Order of browsers to search for cookies. 
# Options: safari, chrome, chromium, edge, firefox.
# Default: safari,chrome,chromium,edge,firefox
BROWSER_PREFERENCE=chrome,safari,firefox

# ─── Cloud API Keys ───────────────────────────────────────────────────────────
# Get keys from these services and paste them below.

# GitHub Copilot: https://github.com/settings/tokens
GITHUB_TOKEN=

# zAI API (Balance) & zAI Plan (Quota): https://api.z.ai
ZAI_API_KEY=

# Kimi API (Balance): https://api.moonshot.cn
KIMI_API_KEY=

# Kimi Coding (IDE Quotas): https://www.kimi.com/code (Get from cookie 'kimi-auth')
KIMI_AUTH_TOKEN=

# OpenRouter (Balance): https://openrouter.ai/keys
OPENROUTER_API_KEY=

# MiniMax (IDE Quotas): https://api.minimaxi.com
MINIMAX_API_KEY=

# Ollama Cloud (Quota): https://ollama.com/settings (Get from cookie 'session')
OLLAMA_SESSION_TOKEN=

# ─── OAuth & Advanced (Optional) ──────────────────────────────────────────────
# Google OAuth (Gemini): Leave blank to auto-discover from ~/.gemini/oauth_creds.json
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=

# Anthropic OAuth (Claude): Leave blank to auto-discover from ~/.claude/.credentials.json
CLAUDE_OAUTH_CLIENT_ID=
